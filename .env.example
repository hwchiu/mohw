# LLM 設定
LLM_BASE_URL=http://test.com
LLM_MODEL_ID=my-model
LLM_API_KEY=none
LLM_TIMEOUT=120
LLM_MAX_TOKENS=4096

# Prometheus 設定
PROMETHEUS_URL=http://localhost:9090

# 節點篩選（強烈建議設定，避免多節點資料混淆分析結果）
# TARGET_NODE: 節點名稱，對應 Prometheus label 的值
#   node_exporter 環境範例：192.168.1.10:9100 或 worker-01
#   k8s 環境範例：worker-node-1
# NODE_LABEL: 代表節點的 label 名稱（node_exporter 通常是 instance，k8s 通常是 node）
# TARGET_NODE=
NODE_LABEL=instance


ANOMALY_SIGMA=2.5
MAX_ANOMALIES=20
# ANALYSIS_MODE=   # 留空為自動偵測；可設為 a / b / c
