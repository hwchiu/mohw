# LLM 設定
LLM_BASE_URL=http://test.com
LLM_MODEL_ID=my-model
LLM_API_KEY=none
LLM_TIMEOUT=120
LLM_MAX_TOKENS=4096

# Prometheus 設定
PROMETHEUS_URL=http://localhost:9090

# SSL / HTTPS 設定
# PROMETHEUS_SSL_VERIFY 可設為：
#   true（預設）  → 載入系統憑證（/etc/ssl/certs 或 Windows/macOS 信任鏈）
#   false         → 跳過憑證驗證（僅限測試環境，不建議正式使用）
#   /path/to/ca.crt → 指定自訂 CA bundle 檔案路徑（適合自簽憑證 / 內部 CA）
# PROMETHEUS_SSL_VERIFY=true

# 節點篩選（強烈建議設定，避免多節點資料混淆分析結果）
# TARGET_NODE: 節點名稱，對應 Prometheus label 的值
#   node_exporter 環境範例：192.168.1.10:9100 或 worker-01
#   k8s 環境範例：worker-node-1
# NODE_LABEL: 代表節點的 label 名稱（node_exporter 通常是 instance，k8s 通常是 node）
# TARGET_NODE=
NODE_LABEL=instance


ANOMALY_SIGMA=2.5
MAX_ANOMALIES=20
# ANALYSIS_MODE=   # 留空為自動偵測；可設為 a / b / c

# 節點模式並行掃描 workers 數（TARGET_NODE 設定後生效）
SCAN_WORKERS=10
